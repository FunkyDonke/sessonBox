rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sessions stored by the shim: sb_users_{uid}_private_sessions/{docId}
    // The shim creates collection names like "sb_users_UID_private_sessions"
    match /{collection}/{document} {
      allow read, write: if request.auth != null 
        && collection.matches('sb_users_' + request.auth.uid + '_.*');
    }
    // Dashboard sessions: users/{uid}/sessions/{sessionId}  
    match /users/{userId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // User profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
